NEWS_CHATS_RU=<comma_separated_chat_ids>

QUIZ_CHATS_KK=<comma_separated_chat_ids>
QUIZ_CHATS_ZH=<comma_separated_chat_ids>
QUIZ_CHATS_RU=<comma_separated_chat_ids>

TELEGRAM_BOT_TOKEN=<your_bot_token>
TELEGRAM_WEBHOOK_SECRET_TOKEN=<your_webhook_secret_token>

GEMINI_API_KEY=<your_gemini_api_key>
