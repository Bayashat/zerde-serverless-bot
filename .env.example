AI_PROVIDER=gemini
DEFAULT_LANG=kk
LLM_MODEL=gemini-2.5-flash
TELEGRAM_API_BASE=https://api.telegram.org/bot

NEWS_CHATS_KK=<comma_separated_chat_ids>
